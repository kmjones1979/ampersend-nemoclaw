# ampersend — agent payments via x402 (https://github.com/edgeandnode/ampersend-sdk)
# The ampersend CLI stores config locally (~/.ampersend/).
# These env vars are optional overrides for the CLI defaults.

# Optional: override the ampersend API URL (default: https://api.ampersend.ai)
# AMPERSEND_API_URL=https://api.ampersend.ai

# Optional: override the network (default: base; options: base, base-sepolia)
# AMPERSEND_NETWORK=base

# NemoClaw / OpenShell sandbox name (used by setup:docker)
SANDBOX_NAME=my-assistant

# Optional: NVIDIA API key for NemoClaw inference (prompted by install if not set)
# NVIDIA_API_KEY=
